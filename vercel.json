{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "X-XSS-Protection",          "value": "1; mode=block" },
        { "key": "Permissions-Policy",        "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://*.workers.dev https://workers.quidditydigital.com https://script.google.com; frame-src https://challenges.cloudflare.com; object-src 'none'; base-uri 'self'"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/styles.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/(notion|script|config|homepage-blog-snippet)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=7200" }
      ]
    }
  ],

  "redirects": [
    {
      "source": "/blog",
      "destination": "/all-posts.html",
      "permanent": true
    },
    {
      "source": "/insights",
      "destination": "/all-posts.html",
      "permanent": true
    },
    {
      "source": "/sitemap",
      "destination": "/sitemap.xml",
      "permanent": false
    }
  ],

  "rewrites": [],

  "cleanUrls": false,
  "trailingSlash": false
}
